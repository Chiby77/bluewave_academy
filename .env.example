# =============================================================================
# Bluewave Academy — Production Environment Variables
# =============================================================================
# HOW TO USE:
#   1. Copy this file to .env  (cp .env.example .env)
#   2. Fill in every value below — replace ALL angle-bracket placeholders
#   3. Never commit .env to git — it is already in .gitignore
#
# On Railway: paste each variable into  Project → Variables  (not a .env file)
# =============================================================================


# =============================================================================
# DJANGO CORE
# =============================================================================

# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=<paste-generated-secret-key-here>

# Set to False in production — NEVER leave True on a live server
DEBUG=False

# Comma-separated list of domains that can serve this app
# Include your Railway subdomain AND your custom domain (if any)
# Example: myapp.up.railway.app,www.bluewaveacademy.com,bluewaveacademy.com
DJANGO_ALLOWED_HOSTS=<yourapp>.up.railway.app,<yourcustomdomain.com>

# Must start with https:// — same domains as above
# Example: https://myapp.up.railway.app,https://www.bluewaveacademy.com
CSRF_TRUSTED_ORIGINS=https://<yourapp>.up.railway.app,https://<yourcustomdomain.com>

# Python logging level for the root logger (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=WARNING
DJANGO_LOG_LEVEL=INFO


# =============================================================================
# DATABASE — Railway PostgreSQL
# =============================================================================
# Railway automatically sets DATABASE_URL when you add a Postgres plugin.
# You do NOT need to set this manually on Railway — it is injected for you.
# Only set it here for local dev if you want to use Postgres instead of SQLite.
#
# Find it in: Railway → Your Project → Postgres plugin → Connect → DATABASE_URL
DATABASE_URL=postgresql://<user>:<password>@<host>.railway.internal:5432/<dbname>

# These are only used if DATABASE_URL is not set (e.g. external Postgres host)
DATABASE_ENGINE=postgresql
POSTGRES_NAME=bluewave
POSTGRES_USER=<postgres-username>
POSTGRES_PASSWORD=<postgres-password>
POSTGRES_HOST=<postgres-host>
POSTGRES_PORT=5432


# =============================================================================
# REDIS — Railway Redis plugin
# =============================================================================
# Railway automatically sets REDIS_URL when you add a Redis plugin.
# You do NOT need to set this manually on Railway — it is injected for you.
# Only set it here for local dev if you want real Redis instead of in-memory.
#
# Find it in: Railway → Your Project → Redis plugin → Connect → REDIS_URL
REDIS_URL=redis://default:<password>@<host>.railway.internal:6379


# =============================================================================
# SUPABASE — Storage (S3-compatible) + API
# =============================================================================
# All values come from your Supabase project dashboard.
# https://supabase.com → Select your project

# ── Project URL & API Keys ────────────────────────────────────────────────────
# Found in: Project Settings → API

# Your project's base URL — looks like: https://abcdefghijkl.supabase.co
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Public anon key — safe to expose in frontend; used for public Supabase calls
# Found in: Project Settings → API → Project API keys → anon / public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<your-anon-key>

# Service role key — KEEP SECRET, has full DB access, used server-side only
# Found in: Project Settings → API → Project API keys → service_role / secret
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<your-service-role-key>

# ── S3-Compatible Storage Credentials ────────────────────────────────────────
# Found in: Project Settings → Storage → S3 Connection
# (You may need to enable S3 protocol — toggle it on in that settings page)

# Storage endpoint — looks like: https://abcdefghijkl.supabase.co/storage/v1/s3
SUPABASE_S3_ENDPOINT=https://<your-project-ref>.supabase.co/storage/v1/s3

# Region is always "auto" for Supabase
SUPABASE_S3_REGION=auto

# S3 Access Key ID — shown once when you create an S3 access key in Supabase
# Found in: Project Settings → Storage → S3 Connection → New access key
SUPABASE_S3_ACCESS_KEY=<your-supabase-s3-access-key-id>

# S3 Secret Access Key — shown once, copy it immediately
SUPABASE_S3_SECRET_KEY=<your-supabase-s3-secret-access-key>

# ── Bucket Names ──────────────────────────────────────────────────────────────
# Create these buckets in: Supabase Dashboard → Storage → New bucket
# Both should be set to PRIVATE (access controlled via signed URLs)

# General media bucket: profile pics, blog images, tutorial files,
# classroom materials (notes/PDFs), student PDF submissions
SUPABASE_MEDIA_BUCKET=media

# Special papers bucket: exam papers served with short-lived signed URLs
SUPABASE_PAPERS_BUCKET=papers


# =============================================================================
# EMAIL — SMTP
# =============================================================================
# For Gmail: use an App Password (not your account password)
#   Google Account → Security → 2-Step Verification → App passwords
# For other providers: use their SMTP credentials / API keys

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# The Gmail address (or sending address for other providers)
EMAIL_HOST_USER=<youremail@gmail.com>

# Gmail App Password (16 chars, no spaces) or provider API key
EMAIL_HOST_PASSWORD=<your-app-password-or-api-key>

# Display name + address shown in the From field of every email
DEFAULT_FROM_EMAIL=Bluewave Academy <noreply@bluewaveacademy.com>


# =============================================================================
# AI SERVICES
# =============================================================================
# Get your key from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_<your-groq-api-key>


# =============================================================================
# PRODUCTION SECURITY
# =============================================================================
# Leave at defaults below — only change if you have a specific reason to

# Redirect all HTTP traffic to HTTPS (True recommended on Railway)
SECURE_SSL_REDIRECT=True

# How long browsers remember to use HTTPS — 1 year in seconds (recommended)
SECURE_HSTS_SECONDS=31536000
